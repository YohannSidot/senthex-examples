# Copy to .env, fill the values, then `source .env` (or use any loader).
# The examples read these via os.environ / process.env — no python-dotenv required.

# Senthex project key. Sign up at https://senthex.com — free tier, 1000 calls/month,
# no credit card. Keys start with snx- followed by 32 url-safe characters.
SENTHEX_API_KEY=snx-replace-me

# Your LLM provider keys. Senthex forwards the Authorization header (or x-api-key
# for Anthropic) to the upstream provider as-is — Senthex never stores it.
OPENAI_API_KEY=sk-replace-me
ANTHROPIC_API_KEY=sk-ant-replace-me
MISTRAL_API_KEY=replace-me
